// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    // output   = "../src/generated/prisma-client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Vendor {
    id           String  @id @default(cuid())
    userId       String  @unique @map("user_id") // Links to User from Auth service
    businessName String  @map("business_name")
    businessType String  @map("business_type")
    description  String?
    contactPhone String? @map("contact_phone")
    address      String
    city         String
    state        String
    zipCode      String  @map("zip_code")
    country      String

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relation to stores (one vendor can have multiple stores)
    stores Store[]

    @@map("vendors")
}

model Store {
    id          String  @id @default(cuid())
    vendorId    String  @map("vendor_id")
    name        String
    slug        String  @unique // URL-friendly identifier
    description String?
    settings    Json? // store configuration as JSON
    isActive    Boolean @default(true) @map("is_active")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    // Relations
    vendor             Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
    categories         Category[]
    variantAttributes  VariantAttribute[]
    products           Product[]

    @@map("stores")
}

// ============================================
// CATEGORIES & TAGS
// ============================================

model Category {
    id          String    @id @default(cuid())
    name        String
    slug        String
    description String?
    parentId    String?   @map("parent_id")
    
    // Scope: null = global, storeId = custom for that store
    storeId     String?   @map("store_id")
    
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")
    
    // Relations
    parent      Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
    children    Category[]        @relation("CategoryHierarchy")
    store       Store?            @relation(fields: [storeId], references: [id], onDelete: Cascade)
    products    ProductCategory[]
    
    @@unique([slug, storeId])
    @@map("categories")
}

model Tag {
    id        String   @id @default(cuid())
    name      String
    slug      String   @unique
    
    createdAt DateTime @default(now()) @map("created_at")
    
    products  ProductTag[]
    
    @@map("tags")
}

model ProductTag {
    productId String @map("product_id")
    tagId     String @map("tag_id")
    
    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
    
    @@id([productId, tagId])
    @@map("product_tags")
}

// ============================================
// VARIANT ATTRIBUTES (Predefined + Custom)
// ============================================

model VariantAttribute {
    id          String   @id @default(cuid())
    name        String
    slug        String
    
    // Scope: null = global/predefined, storeId = custom for that store
    storeId     String?  @map("store_id")
    
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")
    
    // Relations
    store             Store?              @relation(fields: [storeId], references: [id], onDelete: Cascade)
    values            VariantAttributeValue[]
    productAttributes ProductAttribute[]
    
    @@unique([slug, storeId])
    @@map("variant_attributes")
}

model VariantAttributeValue {
    id          String   @id @default(cuid())
    attributeId String   @map("attribute_id")
    value       String
    slug        String
    
    createdAt   DateTime @default(now()) @map("created_at")
    
    // Relations
    attribute     VariantAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
    variantValues VariantValue[]
    images        ProductImage[]
    
    @@unique([attributeId, slug])
    @@map("variant_attribute_values")
}

// ============================================
// PRODUCTS
// ============================================

model Product {
    id          String   @id @default(cuid())
    storeId     String   @map("store_id")
    
    name        String
    slug        String
    description String?  @db.Text
    
    // Base pricing in cents/pence (for products without variants)
    basePrice      Int      @map("base_price")
    comparePrice   Int?     @map("compare_price")
    cost           Int?
    
    // Inventory (for simple products without variants)
    trackInventory    Boolean @default(true) @map("track_inventory")
    stock             Int     @default(0)
    lowStockThreshold Int?    @map("low_stock_threshold")
    
    // Status
    isActive    Boolean  @default(true) @map("is_active")
    isFeatured  Boolean  @default(false) @map("is_featured")
    
    // SEO
    metaTitle       String? @map("meta_title")
    metaDescription String? @map("meta_description")
    
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")
    
    // Relations
    store       Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
    images      ProductImage[]
    tags        ProductTag[]
    categories  ProductCategory[]
    attributes  ProductAttribute[]
    variants    ProductVariant[]
    
    @@unique([storeId, slug])
    @@map("products")
}

model ProductCategory {
    productId  String @map("product_id")
    categoryId String @map("category_id")
    
    product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
    category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    
    @@id([productId, categoryId])
    @@map("product_categories")
}

model ProductAttribute {
    id          String   @id @default(cuid())
    productId   String   @map("product_id")
    attributeId String   @map("attribute_id")
    position    Int      @default(0)
    
    product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
    attribute   VariantAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
    
    @@unique([productId, attributeId])
    @@map("product_attributes")
}

// ============================================
// PRODUCT VARIANTS
// ============================================

model ProductVariant {
    id          String   @id @default(cuid())
    productId   String   @map("product_id")
    
    // Variant identification
    sku         String?  @unique
    barcode     String?
    
    // Pricing in cents/pence
    price          Int
    comparePrice   Int?     @map("compare_price")
    cost           Int?
    
    // Inventory
    stock       Int      @default(0)
    
    // Status
    isActive    Boolean  @default(true) @map("is_active")
    
    // Physical properties
    weight      Int?     // in grams
    
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")
    
    // Relations
    product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
    values      VariantValue[]
    
    @@map("product_variants")
}

model VariantValue {
    id               String   @id @default(cuid())
    variantId        String   @map("variant_id")
    attributeValueId String   @map("attribute_value_id")
    
    variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
    attributeValue   VariantAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
    
    @@unique([variantId, attributeValueId])
    @@map("variant_values")
}

// ============================================
// PRODUCT IMAGES
// ============================================

model ProductImage {
    id                String   @id @default(cuid())
    productId         String   @map("product_id")
    url               String
    altText           String?  @map("alt_text")
    position          Int      @default(0)
    isFeatured        Boolean  @default(false) @map("is_featured")
    
    // Link image to specific variant attribute value (e.g., show this image for "Red")
    variantValueId    String?  @map("variant_value_id")
    
    createdAt         DateTime @default(now()) @map("created_at")
    
    // Relations
    product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
    variantValue      VariantAttributeValue? @relation(fields: [variantValueId], references: [id], onDelete: SetNull)
    
    @@map("product_images")
}
